{
  "name": "user",
  "version": "1.0.0-0",
  "description": "@imqueue Car-Wash tutorial: MongoDB-backed user & garage RPC microservice",
  "keywords": [],
  "type": "module",
  "main": "index.js",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "npm run clean:compiled && tsc",
    "test": "npm run build && node --test --test-timeout=15000 $(find test -name '*.spec.js')",
    "test:coverage": "npm run build && node --enable-source-maps --test --experimental-test-coverage --test-timeout=15000 $(find test -name '*.spec.js')",
    "clean:dts": "find . -name '*.d.ts' -not -wholename '*node_modules*' -type f -delete",
    "clean:map": "find . -name '*.js.map' -not -wholename '*node_modules*' -type f -delete",
    "clean:js": "find . -name '*.js' -not -wholename '*node_modules*' -type f -delete",
    "clean:compiled": "npm run clean:js && npm run clean:dts && npm run clean:map",
    "clean:build": "rm -rf ./node_modules/@types ; find . -name '*.js.map' -type f -delete ; find . -name '*.ts' -type f -delete",
    "clean:test": "rm -rf coverage",
    "clean": "npm run clean:test && npm run clean:compiled",
    "start": "NODE_ENV=production /usr/bin/env node ./index.js LABEL=user",
    "stop": "kill -s TERM $(ps aux | grep 'LABEL=user' | awk '{print $2}')",
    "dev:run": "npm run build && LABEL=user /usr/bin/env node ./index.js",
    "dev": "./node_modules/nodemon/bin/nodemon.js",
    "docker:build": "tsc && docker build -f Dockerfile -t user .",
    "docker:run": "docker run --rm -it --name user user",
    "docker:stop": "docker stop user",
    "docker:ssh": "docker exec -it user sh",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format:check": "oxfmt --check",
    "format": "oxfmt --no-error-on-unmatched-pattern",
    "prepare": "if [ \"$NODE_ENV\" != \"production\" ]; then husky; fi"
  },
  "lint-staged": {
    "*.ts": [
      "oxlint --fix",
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:imqueue-sandbox/user.git"
  },
  "bugs": {
    "url": "https://github.com/imqueue-sandbox/user/issues"
  },
  "homepage": "https://github.com/imqueue-sandbox/user",
  "author": "Mykhailo Stadnyk <mikhus@gmail.com>",
  "license": "ISC",
  "dependencies": {
    "@imqueue/core": "*",
    "@imqueue/rpc": "*",
    "bcryptjs": "^3.0.3",
    "mongoose": "^9.8.0",
    "reflect-metadata": "*",
    "typescript": "*"
  },
  "devDependencies": {
    "@types/node": "*",
    "husky": "*",
    "lint-staged": "*",
    "nodemon": "*",
    "oxfmt": "*",
    "oxlint": "*"
  }
}
