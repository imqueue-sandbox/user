{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "semi": true,
    "trailingComma": "all",
    "singleQuote": true,
    "printWidth": 80,
    "tabWidth": 4,
    "arrowParens": "avoid",
    "sortPackageJson": false,
    "sortImports": {
        "newlinesBetween": false,
        "groups": [
            "type-import",
            ["value-builtin", "value-external"],
            "type-internal",
            "value-internal",
            ["type-parent", "type-sibling", "type-index"],
            ["value-parent", "value-sibling", "value-index"],
            "unknown"
        ]
    },
    "ignorePatterns": [
        "node_modules",
        "*.json",
        "*.d.ts",
        "*.yml",
        "*.yaml"
    ]
}
